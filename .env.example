# PostgreSQL credentials — copy to .env and fill in real values
POSTGRES_DB=urlshortener
POSTGRES_USER=user
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# JWT — must be at least 32 characters; use a random secret in production
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars

# CORS — set to your frontend origin in production
CORS_ALLOWED_ORIGIN=http://localhost:5173

# MaxMind GeoLite2 database path (geo features disabled if file is absent)
MAXMIND_DB_PATH=./geo/GeoLite2-City.mmdb
